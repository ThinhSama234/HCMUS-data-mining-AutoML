# AutoML Console backend connection (spec 003). Copy to `.env` and adjust.
# Loaded automatically by storage/db.py (python-dotenv) — no `export` needed.
# Leave these UNSET/empty to run with the SQLite + local object-store fallback (no containers).

# --- PostgreSQL (matches docker-compose.yml) ---
DATABASE_URL=postgresql+psycopg2://amlb:amlb@localhost:5432/amlb

# --- MinIO / S3-compatible object store (matches docker-compose.yml) ---
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=amlb
S3_SECRET_KEY=amlb12345

# --- Container CLI for framework integration (optional) ---
# Auto-detected from docker / nerdctl / podman on PATH; override if needed:
# CONTAINER_CLI=nerdctl

# --- Kaggle dataset import (spec 006) — a public link STILL needs a token ---
# Create at kaggle.com → Account → "Create New API Token" (downloads kaggle.json to ~/.kaggle/),
# or set the pair below. Leave unset to disable import (rule R2-credentials explains it in the UI).
# KAGGLE_USERNAME=your_kaggle_username
# KAGGLE_KEY=your_kaggle_key
# KAGGLE_MAX_FILE_MB=200
